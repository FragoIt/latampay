// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  walletAddress String?  @unique
  
  // Subscription
  plan          Plan     @default(FREE)
  addOns        AddOn[]  @default([])
  stripeId      String?  @unique
  
  // Usage tracking
  monthlyVolume Decimal  @default(0) @db.Decimal(20, 2)
  monthlyInvoices Int    @default(0)
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  invoices      Invoice[]
  subscriptions Subscription[]
  
  @@index([email])
  @@index([plan])
}

enum Plan {
  FREE
  PRO
  GROWTH
  SCALE
  ENTERPRISE
}

enum AddOn {
  FISCAL
  ANALYTICS
  RECURRING
  PAYOUTS
  KYC
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  
  // Customer info
  customerEmail String
  customerName  String
  customerId    String?
  
  // Payment details
  amount        Decimal       @db.Decimal(20, 2)
  currency      String        @default("USDC")
  token         String?       // Token address if paid
  status        InvoiceStatus @default(PENDING)
  
  // Dates
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  paidAt        DateTime?
  
  // Blockchain
  paymentId     String?       @unique // bytes32 from contract
  txHash        String?       @unique
  
  // Metadata
  description   String?
  metadata      Json?
  
  // Relations
  user          User          @relation(fields: [userId], references: [id])
  userId        String
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Subscription {
  id              String            @id @default(uuid())
  
  // Subscription details
  clientId        String
  customerEmail   String
  customerName    String
  amount          Decimal           @db.Decimal(20, 2)
  currency        String            @default("USDC")
  interval        Interval          @default(MONTHLY)
  
  // Status
  status          SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  
  // Billing
  nextBillingDate DateTime?
  lastPaymentDate DateTime?
  failedAttempts  Int               @default(0)
  
  // Metadata
  description     String?
  metadata        Json?
  
  // Relations
  user            User              @relation(fields: [userId], references: [id])
  userId          String
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([nextBillingDate])
}

enum Interval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

