{
  "name": "@latampay/sdk",
  "version": "1.0.0",
  "description": "LatamPay TypeScript SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@latampay/monitoring": "workspace:*",
    "@latampay/types": "workspace:*",
    "ethers": "^6.10.0",
    "eventemitter3": "^5.0.1",
    "qrcode": "^1.5.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@latampay/config": "workspace:*",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
