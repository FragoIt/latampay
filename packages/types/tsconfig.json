{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@latampay/config": ["../config"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}

